{
  "id": "act1_ch1_pre",
  "lines": [
    {"speaker": "黑鱼", "text": "林子很黑。火把一熄，他们就看不见我们。", "next": 1},
    {"speaker": "罗柏", "text": "可我们也看不见他们。", "next": 2},
    {"speaker": "黑鱼", "text": "所以我们先动。詹姆的人还在睡梦里数战利品。", "next": 3},
    {"speaker": "凯特琳", "text": "罗柏——把你的人带回来。", "next": 4},
    {"speaker": "罗柏", "text": "我会的，母亲。", "next": 5}
  ]
}
