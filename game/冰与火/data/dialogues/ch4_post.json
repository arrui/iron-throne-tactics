  "id": "ch4_post",
  "lines": [
    {
      "speaker": "劳勃",
      "text": "奈德。",
      "next": 1
    },
    {
      "speaker": "奈德",
      "text": "劳勃。伤好了？",
      "next": 2
    },
    {
      "speaker": "劳勃",
      "text": "差不多。椅子比我想象的更硬。",
      "next": 3
    },
    {
      "speaker": "奈德",
      "text": "……",
      "next": 4
    },
    {
      "speaker": "劳勃",
      "text": "我需要你，奈德。我需要你留下来做我的首相。你比这里任何人都更让我信任。",
      "next": 5
    },
    {
      "speaker": "奈德",
      "text": "……我要回北境了，劳勃。",
      "next": 6
    },
    {
      "speaker": "劳勃",
      "text": "（沉默）……我就知道你会这么说。",
      "next": 7
    },
    {
      "speaker": "奈德",
      "text": "这里有你坐镇，这里就是安全的。北境只有我能去。",
      "next": -1
    }
  ]
}
